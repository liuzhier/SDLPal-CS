<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:CommonCtrl="using:AvaloniaControl"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ModTools.Ui.MainWindow"
        WindowStartupLocation="CenterScreen"
        MinWidth="800" MinHeight="400"
        Width="800" Height="400"
        Title="Pal Mod Tools">
    <Grid>
        <Grid.Styles>
            <Style Selector="Label">
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style Selector="Grid > Border">
                <Setter Property="Margin" Value="8, 4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="Pink" />
            </Style>
        </Grid.Styles>
        <Grid RowDefinitions="Auto, Auto, Auto, *">
            <CommonCtrl:AuthorNote />
            <Grid x:Name="pathOption_Grid" Grid.Row="1">
                <Border Grid.Row="0">
                    <Grid RowDefinitions="3*, 3*, 3*">
                        <Grid.Styles>
                            <Style Selector="CommonCtrl|PathBox">
                                <Setter Property="Margin" Value="0, 5, 0, 5" />
                            </Style>
                        </Grid.Styles>
                        <CommonCtrl:PathBox x:Name="GamePath_PathBox" Grid.Row="0" Title="Game Path" Text="..\" FontSize="24" />
                        <CommonCtrl:PathBox x:Name="ModPath_PathBox" Grid.Row="1" Title="Mod Path" Text=".\" FontSize="24" />
                    </Grid>
                </Border>
            </Grid>
            <Grid x:Name="functionOption_Grid" Grid.Row="2">
                <Grid.Styles>
                    <Style Selector="Grid > Label">
                        <Setter Property="Foreground" Value="DeepPink" />
                    </Style>
                    <Style Selector="Grid > Button">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="VerticalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="Margin" Value="6" />
                    </Style>
                </Grid.Styles>
                <Grid ColumnDefinitions="3*, 7*">
                    <Border Grid.Column="0">
                        <Grid RowDefinitions="1*, 1*">
                            <Label Grid.Row="0">Author</Label>
                            <Label Grid.Row="1" FontSize="20" Foreground="#FF8080">Chunxiao Li</Label>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1">
                        <Grid RowDefinitions="1*, 1*">
                            <Label Grid.Row="0">Unpacking Options</Label>
                            <Button x:Name="UnpackButton" Grid.Row="1">Unpack</Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <Border Grid.Row="3">
                <Grid RowDefinitions="Auto, 10*">
                    <Label Grid.Row="0" Foreground="DeepPink">Console Log</Label>
                    <TextBox x:Name="LogBox_TextBox" Grid.Row="1" FontSize="20" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Visible"></TextBox>
                </Grid>
            </Border>
        </Grid>
        <CommonCtrl:MessageBox x:Name="MsgBox" Background="#9FFFC0CB" IsVisible="False" />
    </Grid>
</Window>
